{
  "name": "samwise-vscode",
  "displayName": "Samwise",
  "description": "Your faithful coding assistant, from green fields to Mount Doom",
  "version": "0.1.0",
  "publisher": "wave",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "samwise-sidebar",
          "title": "Samwise",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "samwise-sidebar": [
        {
          "type": "webview",
          "id": "samwise.activityFeed",
          "name": "Activity Feed"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "samwise.chat",
        "name": "samwise",
        "fullName": "Samwise",
        "description": "Your faithful coding assistant",
        "isSticky": true,
        "commands": [
          {
            "name": "sprint",
            "description": "Show sprint board summary"
          },
          {
            "name": "calendar",
            "description": "Show upcoming meetings (next 2 hours)"
          },
          {
            "name": "status",
            "description": "Show current activity status"
          },
          {
            "name": "break",
            "description": "Toggle break reminder"
          },
          {
            "name": "do",
            "description": "Execute a task (e.g., merge a PR, implement a ticket)"
          },
          {
            "name": "help",
            "description": "List available commands"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "samwise.openPanel",
        "title": "Samwise: Open Activity Feed"
      },
      {
        "command": "samwise.refreshFeed",
        "title": "Samwise: Refresh Activity Feed",
        "icon": "$(refresh)"
      },
      {
        "command": "samwise.showSummary",
        "title": "Samwise: Show Today's Summary"
      },
      {
        "command": "samwise.showBackendLog",
        "title": "Samwise: Show Backend Log"
      },
      {
        "command": "samwise.setGithubToken",
        "title": "Samwise: Set GitHub Token"
      },
      {
        "command": "samwise.setJiraToken",
        "title": "Samwise: Set Jira API Token"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "samwise.refreshFeed",
          "when": "view == samwise.activityFeed",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Samwise",
      "properties": {
        "samwise.github.username": {
          "type": "string",
          "default": "",
          "description": "Your GitHub username (for PR / notification monitoring)."
        },
        "samwise.jira.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Jira instance base URL, e.g. https://yourorg.atlassian.net"
        },
        "samwise.jira.email": {
          "type": "string",
          "default": "",
          "description": "Email address for Jira API authentication."
        },
        "samwise.google.clientSecretPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Google OAuth client_secret JSON file (for Calendar integration)."
        },
        "samwise.backend.port": {
          "type": "number",
          "default": 9474,
          "description": "Preferred port for the backend server (auto-picks another if occupied)."
        },
        "samwise.backend.pollIntervalSeconds": {
          "type": "number",
          "default": 120,
          "description": "How often (in seconds) sensors poll for new data."
        },
        "samwise.backend.autoMerge": {
          "type": "boolean",
          "default": false,
          "description": "Allow Samwise to auto-merge approved PRs that pass CI."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint src/",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0"
  }
}
