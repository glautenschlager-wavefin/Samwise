# Samwise configuration — copy to .env and fill in your values.
# The SAMWISE_ prefix is required for all variables.

# --- GitHub ---
SAMWISE_GITHUB_TOKEN=
SAMWISE_GITHUB_USERNAME=

# --- Jira (Atlassian Cloud) ---
SAMWISE_JIRA_BASE_URL=https://waveaccounting.atlassian.net
SAMWISE_JIRA_EMAIL=
SAMWISE_JIRA_API_TOKEN=

# --- Server ---
# SAMWISE_HOST=127.0.0.1
# SAMWISE_PORT=9474
# SAMWISE_POLL_INTERVAL_SECONDS=120

# --- Behavior ---
# SAMWISE_AUTO_MERGE=false
# SAMWISE_DATA_DIR=~/.samwise
